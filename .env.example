# EHealth Identity — Environment Variables
# Copy this file to .env and fill in your values
# ⚠️ NEVER commit .env to GitHub — add it to .gitignore

# Get from Alchemy (free): https://alchemy.com
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/rd1SOGYez13oUI_q-SPlm

# Your MetaMask private key (MetaMask → Account Details → Export Private Key)
# Start with 0x
PRIVATE_KEY= # Example - 0x

# Get from Etherscan (free): https://etherscan.io/myapikey
ETHERSCAN_API_KEY=  #

# Pinata IPFS upload credentials
# Use either JWT OR API key + secret key
# Get JWT from: https://app.pinata.cloud/developers/api-keys
VITE_PINATA_JWT= 
# Or use these instead of JWT:
VITE_PINATA_API_KEY= # Example -your_pinata_api_key_here
ITE_PINATA_SECRET_KEY= # Example -your_pinata_secret_key_here
