# EHealth Identity — Environment Variables
# Copy this file to .env and fill in your values
# ⚠️ NEVER commit .env to GitHub — add it to .gitignore

# Get from Alchemy (free): https://alchemy.com
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY_HERE

# Your MetaMask private key (MetaMask → Account Details → Export Private Key)
# Start with 0x
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Get from Etherscan (free): https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY_HERE
